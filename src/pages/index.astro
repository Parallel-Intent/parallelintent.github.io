---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
---

<Base title="Aligned at the source">
    <main>
        <div class="top-bar">
            <div class="name">Parallel Intent</div>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
                Light
            </button>
        </div>

        <div class="hero">
            <h1 class="tagline">
                <span class="word">Aligned</span>
                <span class="word">at</span>
                <span class="word">the</span>
                <em class="word">source.</em>
            </h1>
            <div class="divider"></div>
            <div class="manifesto">
                <p>
                    The next era of software isn't built by humans or machines.
                    It's built by both, in parallel, toward the same goal.
                </p>
                <p>
                    Parallel Intent exists at that intersection. Where intent is
                    the input. Where alignment is the architecture. Where every
                    commit moves in one direction.
                </p>
                <p>Not faster tools. A new way of building.</p>
            </div>
        </div>

        <div class="bottom-bar">
            <Nav />
            <div class="status">
                <span class="dot"></span>
                <span>Building</span>
                <span class="sep">/</span>
                <span>Tirana</span>
                <span class="sep">/</span>
                <span>2026</span>
            </div>
        </div>
    </main>
</Base>

<style>
    main {
        position: relative;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 3rem;
        z-index: 10;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.2s forwards;
    }

    .name {
        font-family: "Syne", sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--fg);
    }

    .hero {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 780px;
    }

    .tagline {
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: clamp(2.6rem, 6vw, 5rem);
        line-height: 1.08;
        letter-spacing: -0.03em;
        color: var(--fg);
        opacity: 0;
        animation: fadeUp 1s ease 0.5s forwards;
    }

    .tagline .word {
        display: inline-block;
        margin-right: 0.25em;
        transition: color 0.3s ease;
    }

    .tagline .word:hover {
        color: var(--accent);
    }

    .tagline em {
        font-style: italic;
        color: var(--accent);
        text-shadow: 0 0 30px color-mix(in srgb, var(--accent) 25%, transparent);
    }

    .divider {
        width: 2rem;
        height: 1px;
        background: var(--muted);
        margin: 2.5rem 0;
        opacity: 0;
        animation: fadeIn 0.8s ease 0.9s forwards;
    }

    .manifesto {
        max-width: 440px;
        opacity: 0;
        animation: fadeUp 0.8s ease 1s forwards;
    }

    .manifesto p {
        font-size: 0.78rem;
        line-height: 1.85;
        color: var(--muted);
        letter-spacing: 0.01em;
    }

    .manifesto p + p {
        margin-top: 0.8rem;
    }

    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        opacity: 0;
        animation: fadeUp 0.8s ease 1.3s forwards;
    }

    .status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .status .dot {
        display: inline-block;
        width: 4px;
        height: 4px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse 3s ease-in-out infinite;
    }

    .status .sep {
        opacity: 0.3;
    }

    @media (max-width: 640px) {
        main {
            padding: 2rem;
        }
        .status {
            display: none;
        }
    }
</style>
