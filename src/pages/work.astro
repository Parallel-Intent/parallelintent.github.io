---
import Page from "../layouts/Page.astro";
---

<Page title="Work">
  <h1 class="page-title">Work</h1>
  <div class="work-intro">
    <p>
      Parallel Intent is a software studio building at the intersection of
      human intent and machine intelligence.
    </p>
  </div>

  <div class="sections">
    <section class="work-section">
      <div class="section-header">
        <span class="section-icon">◉</span>
        <h2 class="section-label">Orbs</h2>
        <span class="section-tag">open source</span>
      </div>
      <p class="section-desc">
        Small, self-contained tools that solve one problem. Built fast with AI,
        shipped for anyone. Intent in, utility out.
      </p>
      <a href="https://github.com/Parallel-Intent" class="section-link">
        Explore on GitHub <span class="arrow">→</span>
      </a>
    </section>

    <section class="work-section">
      <div class="section-header">
        <span class="section-icon">∿</span>
        <h2 class="section-label">Waves</h2>
        <span class="section-tag">aligned workflows</span>
      </div>
      <p class="section-desc">
        The operating layer between human judgment and machine speed.
        Products that advance how professionals decide, build, and ship.
      </p>
      <div class="section-status">
        <span class="dot"></span>
        In progress
      </div>
    </section>
  </div>
</Page>

<style>
  .page-title {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }

  .work-intro {
    font-size: 0.78rem;
    line-height: 1.85;
    color: var(--muted);
    letter-spacing: 0.01em;
    max-width: 480px;
    margin-bottom: 4rem;
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 520px;
  }

  .work-section {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-icon {
    font-size: 1.1rem;
    color: var(--accent);
    line-height: 1;
  }

  .section-label {
    font-family: "Syne", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .section-tag {
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0.7;
  }

  .section-desc {
    font-size: 0.78rem;
    line-height: 1.85;
    color: var(--muted);
    letter-spacing: 0.01em;
    margin-bottom: 1.2rem;
  }

  .section-link {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .section-link:hover {
    color: var(--fg);
  }

  .section-link .arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .section-link:hover .arrow {
    transform: translateX(4px);
  }

  .section-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .section-status .dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 3s ease-in-out infinite;
  }
</style>
