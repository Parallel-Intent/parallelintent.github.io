---
import Base from "../layouts/Base.astro";
---

<Base title="404">
  <div class="not-found">
    <h1 class="code">404</h1>
    <p class="message">Signal lost.</p>
    <a href="/" class="back">← Back to origin</a>
  </div>

  <style>
    .not-found {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
    }

    .code {
      font-family: "Syne", sans-serif;
      font-size: clamp(6rem, 15vw, 12rem);
      font-weight: 700;
      color: var(--muted);
      line-height: 1;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.2s forwards;
    }

    .message {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 1rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.4s forwards;
    }

    .back {
      margin-top: 2.5rem;
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--accent);
      transition: color 0.3s ease;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.6s forwards;
    }

    .back:hover {
      color: var(--fg);
    }
  </style>
</Base>
